{
  "name": "suitecrm/mcp-server",
  "description": "Hardened Model Context Protocol (MCP) server for SuiteCRM, aligned with NSA MCP security guidance.",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "SuiteCRM MCP Developer",
      "email": "developer@example.com"
    }
  ],
  "require": {
    "php": ">=7.4",
    "ext-curl": "*",
    "ext-json": "*",
    "react/event-loop": "^1.3",
    "react/stream": "^1.2",
    "guzzlehttp/guzzle": "^7.0",
    "vlucas/phpdotenv": "^5.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "SuiteCRM\\MCP\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SuiteCRM\\MCP\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/suitecrm-mcp-server"
  ],
  "scripts": {
    "start": "php suitecrm-mcp-server.php",
    "test": "phpunit",
    "test-security": "phpunit --testsuite security",
    "lint": "phpcs --standard=PSR12 src/ suitecrm-mcp-server.php",
    "lint-fix": "phpcbf --standard=PSR12 src/ suitecrm-mcp-server.php",
    "audit": "composer audit"
  }
}
