# --- SuiteCRM upstream (required) ---------------------------------------------
SUITECRM_URL=https://your-suitecrm-instance.com
SUITECRM_CLIENT_ID=your-oauth2-client-id
SUITECRM_CLIENT_SECRET=your-oauth2-client-secret
SUITECRM_USERNAME=your-username
SUITECRM_PASSWORD=your-password

# --- Authorisation policy (NSA spec 1.1, 7.1) --------------------------------
# Allowlist of SuiteCRM modules this server may touch. Anything not listed
# is denied before any outbound HTTP request is made.
MCP_ALLOWED_MODULES=Accounts,Contacts,Leads,Opportunities,Cases,Calls,Meetings,Tasks,Notes,Emails,Campaigns,Documents

# Explicit consent flags for destructive operations on sensitive zones.
# Default deny; flip to "true" only when operators have signed off.
MCP_ALLOW_DESTRUCTIVE=false
MCP_ALLOW_DESTRUCTIVE_CONFIDENTIAL=false

# --- Resource controls (NSA spec 8.1) ----------------------------------------
MCP_RATE_LIMIT_PER_MINUTE=60
MCP_MAX_PAYLOAD_BYTES=65536
MCP_HTTP_TIMEOUT=15
MCP_TOKEN_IDLE_SECONDS=900

# --- Audit / SIEM (NSA spec 6) ----------------------------------------------
# JSONL file or "php://stderr" for stdout collection by a sidecar.
MCP_AUDIT_LOG=php://stderr
# Optional file path that receives only security-relevant events for SIEM
# forwarders. Empty disables the secondary sink.
MCP_SIEM_ENDPOINT=

# --- Signing / replay (NSA spec 5; inert for stdio) --------------------------
MCP_REQUIRE_SIGNATURES=false
MCP_SIGNING_SECRET=
MCP_REPLAY_WINDOW_SECONDS=300
